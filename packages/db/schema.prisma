generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
}

model SymptomReport {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())
  inputText    String
  age          Int?
  temperature  Float?
  durationDays Int?
  urgency      UrgencyLevel
  context      String
  recommendation Json
  symptomTags  Json
  aiResponse   Json
}
