{
  "name": "triageph",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w frontend",
    "dev:api": "npm run dev -w backend",
    "build": "npm run build:api && npm run build:web",
    "build:vercel": "npm --workspace frontend run build",
    "build:web": "npm run build -w frontend",
    "build:api": "npm run build -w backend",
    "lint": "npm run lint:web",
    "lint:web": "npm run lint -w frontend",
    "clean": "rm -rf backend/dist frontend/.next",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
